# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Private key of the wallet that deploys contracts.
# On local Hardhat this defaults to account #0 (safe test key, do not use on mainnet).
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Besu private network RPC endpoint (HTTP)
# Example: http://192.168.1.10:8545
BESU_RPC_URL=http://127.0.0.1:8545

# Chain ID configured in your Besu genesis file
# Default Hardhat chain ID is 1337 — use the same in Besu for easy local dev
BESU_CHAIN_ID=1337
