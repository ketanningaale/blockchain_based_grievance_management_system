{
  "name": "grievance-blockchain",
  "version": "1.0.0",
  "description": "Smart contracts for the blockchain-based grievance redressal system",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:besu": "hardhat run scripts/deploy.ts --network besu",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "node": "hardhat node",
    "lint": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean",
    "export-abis": "ts-node scripts/export-abis.ts"
  },
  "devDependencies": {
    "dotenv": "^16.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "solhint": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  }
}
