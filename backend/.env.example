# Copy this to .env and fill in real values. Never commit .env.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000

# ── Blockchain (Besu / Hardhat local) ─────────────────────────────────────────
# RPC endpoint of your Besu node (or local Hardhat node)
BESU_RPC_URL=http://127.0.0.1:8545

# Relay wallet — this backend wallet signs all on-chain transactions.
# Fund it with enough ETH/gas on your private network.
# Get these values from the deploy script output (deployments/<network>.json)
RELAY_WALLET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ROLE_MANAGER=0x0000000000000000000000000000000000000000
CONTRACT_GRIEVANCE_SYSTEM=0x0000000000000000000000000000000000000000

# ── Firebase ──────────────────────────────────────────────────────────────────
# Download your service account JSON from Firebase Console →
# Project Settings → Service Accounts → Generate new private key
# Then either paste the values here or set FIREBASE_CREDENTIALS_PATH
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_CERT_URL=

# Institute config (must match what was set in Firestore)
INSTITUTE_EMAIL_DOMAIN=institute.edu.in
INSTITUTE_ID=institute_001

# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────
# Get from app.pinata.cloud → API Keys
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── SendGrid (email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=grievance@institute.edu.in
SENDGRID_FROM_NAME=Grievance Portal

# ── APScheduler ───────────────────────────────────────────────────────────────
# How often the threshold watchdog runs (minutes)
THRESHOLD_CHECK_INTERVAL_MINUTES=30
